query list_products() {
    match {
        $product: Product
    }

    return {
        $product.slug,
        $product.name,
        $product.site_url,
        $product.category,
        $product.status,
        $product.visibility,
        $product.source_file
    }

    limit 50
}

query get_product($product_slug: String) {
    match {
        $product: Product { slug: $product_slug }
    }

    return {
        $product.slug,
        $product.name,
        $product.site_url,
        $product.category,
        $product.status,
        $product.visibility,
        $product.source_file
    }

    limit 1
}

query get_product_features($product_slug: String) {
    match {
        $product: Product { slug: $product_slug }
        $product hasFeature $feature
    }

    return {
        $product.slug,
        $product.name,
        $feature.slug,
        $feature.name,
        $feature.product_area,
        $feature.feature_type,
        $feature.status,
        $feature.visibility
    }

    limit 100
}

query get_product_proof_points($product_slug: String) {
    match {
        $product: Product { slug: $product_slug }
        $product provenBy $proof_point
    }

    return {
        $product.slug,
        $product.name,
        $proof_point.slug,
        $proof_point.name,
        $proof_point.proof_type,
        $proof_point.metric_name,
        $proof_point.metric_value,
        $proof_point.approved_for_external_use,
        $proof_point.visibility
    }

    limit 100
}

query get_product_icp_segments($product_slug: String) {
    match {
        $product: Product { slug: $product_slug }
        $product targets $icp_segment
    }

    return {
        $product.slug,
        $product.name,
        $icp_segment.slug,
        $icp_segment.name,
        $icp_segment.segment_type,
        $icp_segment.status,
        $icp_segment.visibility
    }

    limit 100
}

