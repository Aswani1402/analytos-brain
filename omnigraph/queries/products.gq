query search_entities($slug: String) {
    match {
        $product: Product { slug: $slug }
    }

    return {
        $product.slug,
        $product.name,
        $product.category,
        $product.status,
        $product.visibility,
        $product.source_file
    }

    limit 25
}

query recent_changes() {
    match {
        $extraction_run: ExtractionRun
    }

    return {
        $extraction_run.slug,
        $extraction_run.branch_name,
        $extraction_run.model_name,
        $extraction_run.prompt_version,
        $extraction_run.status,
        $extraction_run.started_at,
        $extraction_run.completed_at,
        $extraction_run.source_count
    }

    limit 25
}
